FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata && adduser -D -u 65532 nonroot
WORKDIR /app
COPY ratchetd-linux ./ratchetd
COPY ui/dist/ ./ui/dist/
COPY ratchet.yaml .
COPY config/ config/
RUN chmod +x ./ratchetd && mkdir -p /app/data && chown nonroot:nonroot /app/data
USER nonroot
EXPOSE 9090
ENTRYPOINT ["./ratchetd"]
CMD ["--config", "ratchet.yaml"]
